# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://mailadmin:mailadmin@db:5432/maildb

# ===== 凭证加密主密钥（务必替换！）=====
# 生成命令：python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
MASTER_KEY=

# ===== 面板登录 =====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
JWT_SECRET=please-change-this-jwt-secret
JWT_EXPIRE_MINUTES=720

# ===== 微软 OAuth2 / IMAP =====
OAUTH_TOKEN_URL=https://login.microsoftonline.com/consumers/oauth2/v2.0/token
OAUTH_SCOPE=https://outlook.office.com/IMAP.AccessAsUser.All offline_access
IMAP_HOST=outlook.office365.com
IMAP_PORT=993

# ===== 收信模式 =====
# 后台全量轮询：低频账号建议【关闭】（false）——平时零操作、最省资源、最保号。
# 需要收码时用「临时监听」（对单账号短时快拉）或「按需刷新」。
# 仅当所有账号都要准实时收信时才设为 true。
POLL_ENABLED=false
POLL_INTERVAL_SECONDS=300
POLL_CONCURRENCY=30
FETCH_MAX_PER_ACCOUNT=30

# ===== 临时监听（等验证码时对单个账号短时快拉）=====
WATCH_INTERVAL_SECONDS=10      # 监听期间每隔多少秒拉一次
WATCH_DURATION_SECONDS=180     # 单次监听最长持续，自动停止
WATCH_MAX_CONCURRENT=20        # 同时最多监听的账号数
