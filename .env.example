# 部署环境变量（复制本文件为 .env 并填写）

# 数据库密码
POSTGRES_PASSWORD=change-this-db-password

# 凭证加密主密钥（32 字节 base64，必填！）
# 生成：python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
MASTER_KEY=

# 面板登录
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
JWT_SECRET=change-this-to-a-long-random-string

# 对外 Web 端口（浏览器访问 http://服务器IP:WEB_PORT）
WEB_PORT=8080

# 收信模式：低频账号保持 false（不后台轮询，用临时监听/按需刷新）
POLL_ENABLED=false
POLL_INTERVAL_SECONDS=300
POLL_CONCURRENCY=30
FETCH_MAX_PER_ACCOUNT=30

# 临时监听（等验证码时对单账号短时快拉）
WATCH_INTERVAL_SECONDS=10
WATCH_DURATION_SECONDS=180
